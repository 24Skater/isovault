# Copy this file to .env and fill in values
# .env is gitignored — never commit secrets

# Bearer token for API authentication
# Auto-generated on first boot if not set
ISO_MANAGER_API_KEY=

# Path to config.yaml (default: ./config.yaml)
ISO_MANAGER_CONFIG=./config.yaml

# SQLite database path (overrides config.yaml)
ISO_MANAGER_DB_PATH=

# ISO storage root path (overrides config.yaml)
ISO_STORE_PATH=

# Log level: debug | info | warn | error
ISO_MANAGER_LOG_LEVEL=info

# HTTP port (overrides config.yaml server.port)
PORT=3721

# Set to "production" to disable dev features (stack traces, pino-pretty, etc.)
NODE_ENV=development
